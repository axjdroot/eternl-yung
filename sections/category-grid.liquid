{%- style -%}
  .sw-category-grid-section {
    padding-top: var(--pad-section-m);
    padding-bottom: var(--pad-section-m);
    background-color: var(--color-bg);
  }
  @media (min-width: 1024px) {
    .sw-category-grid-section {
      padding-top: var(--pad-section);
      padding-bottom: var(--pad-section);
    }
  }
  .sw-category-grid__heading {
    font-family: var(--font-heading-alt);
    font-size: 36px;
    color: var(--color-text);
    text-transform: uppercase;
    margin-bottom: var(--sp-6);
    letter-spacing: 0.06em;
  }
  .sw-category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap-grid);
    /* The 2px mosaic layout */
  }
  @media (min-width: 1024px) {
    .sw-category-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  /* Category Card Snippet Styles */
  .sw-category-card {
    position: relative;
    display: block;
    overflow: hidden;
    background-color: var(--color-surface);
  }
  .sw-category-card__media {
    position: relative;
    width: 100%;
  }
  .sw-category-card__media--1-1 {
    aspect-ratio: 1 / 1;
  }
  .sw-category-card__media--3-4 {
    aspect-ratio: 3 / 4;
  }
  .sw-category-card__img,
  .sw-category-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .sw-category-card:hover .sw-category-card__img {
    transform: scale(1.03);
  }
  .sw-category-card__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 60%;
    background: linear-gradient(to bottom, transparent 0%, rgba(13,13,13,0.85) 100%);
    z-index: 1;
    pointer-events: none;
  }
  .sw-category-card__info {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: var(--sp-4);
    z-index: 2;
    pointer-events: none;
  }
  .sw-category-card__title {
    font-family: var(--font-heading-alt);
    font-size: 20px;
    color: #FFF; /* explicitly white for contrast over overlay */
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 2px;
  }
  .sw-category-card__count {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--color-muted);
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .sw-category-card:hover .sw-category-card__img {
      transform: none;
    }
  }
{%- endstyle -%}

<section class="sw-category-grid-section sw-reveal">
  <div class="sw-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="sw-category-grid__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="sw-category-grid">
      {%- for block in section.blocks -%}
        {% render 'category-card', block: block %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BROWSE CATEGORIES"
    }
  ],
  "max_blocks": 8,
  "blocks": [
    {
      "type": "category",
      "name": "Category Block",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Custom Label",
          "info": "Overrides collection title"
        },
        {
          "type": "text",
          "id": "count_label",
          "label": "Count Label",
          "default": "55 styles"
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Image Ratio",
          "options": [
            { "value": "1-1", "label": "Square (1:1)" },
            { "value": "3-4", "label": "Portrait (3:4)" }
          ],
          "default": "1-1"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
