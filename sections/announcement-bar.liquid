{% if section.settings.show_announcement %}
  {% assign messages = section.blocks | map: 'settings' | map: 'text' | compact %}
  {% if messages.size == 0 %}
    {% assign messages = "FREE SHIPPING ON 4000.PKR" | split: "|" %}
  {% endif %}

  {% if messages.size > 0 %}
    {%- style -%}
      .sw-topbar {
        background-color: #1A1A1A;
        color: #F8F8F8;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 var(--sp-4);
        height: 36px;
        min-height: 40px;
        font-family: var(--font-body);
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.05em;
        position: relative;
        z-index: 1000;
        overflow: visible;
      }
      .sw-topbar__left {
        display: flex;
        align-items: center;
        gap: var(--sp-4);
      }
      .sw-topbar__center {
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1;
        gap: var(--sp-2);
      }
      .sw-topbar__right {
        display: flex;
        align-items: center;
        gap: var(--sp-4);
      }
      .sw-topbar-icon {
        width: 14px;
        height: 14px;
        fill: currentColor;
        transition: opacity var(--dur-fast) ease;
      }
      .sw-topbar-icon:hover {
        opacity: 0.7;
      }
      @media (max-width: 767px) {
        .sw-topbar__left, .sw-topbar__right {
          display: none;
        }
      }
    {%- endstyle -%}

    <div class="sw-topbar" role="region" aria-label="Announcement">
      <div class="sw-topbar__center">
        <a href="#" aria-label="Previous">
          <svg viewBox="0 0 24 24" class="sw-topbar-icon" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        </a>
        <span style="font-family: var(--font-body); font-weight: 400; font-size: 10px; max-width: 200px; text-align: center; line-height: 1.2; text-transform: uppercase;">{{ messages.first }}</span>
        <a href="#" aria-label="Next">
          <svg viewBox="0 0 24 24" class="sw-topbar-icon" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="sw-topbar__right">
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" aria-label="Facebook">
            <svg class="sw-topbar-icon" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        {%- endif -%}
          <a href="{{ settings.social_instagram_link }}" aria-label="Instagram">
            <svg class="sw-topbar-icon" viewBox="0 0 24 24"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.64-.07-4.85s.01-3.58.07-4.85c.15-3.23 1.66-4.77 4.92-4.92 1.27-.06 1.64-.07 4.85-.07M12 0C8.74 0 8.33.01 7.05.07c-4.27.2-6.78 2.71-6.98 6.98C0 8.33 0 8.74 0 12s.01 3.67.07 4.95c.2 4.27 2.71 6.78 6.98 6.98 1.28.06 1.69.07 4.95.07s3.67-.01 4.95-.07c4.27-.2 6.78-2.71 6.98-6.98.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.2-4.27-2.71-6.78-6.98-6.98C15.67.01 15.26 0 12 0zm0 5.84A6.16 6.16 0 1018.16 12 6.16 6.16 0 0012 5.84zm0 10.16A4 4 0 1116 12a4 4 0 01-4 4zm5.22-9.4a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z"/></svg>
          </a>
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" aria-label="YouTube">
            <svg class="sw-topbar-icon" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  {% endif %}
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "s",
      "label": "Scroll speed",
      "default": 15
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "FREE SHIPPING ON 4000.PKR"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "message" },
        { "type": "message", "settings": { "text": "NEW DROP AVAILABLE NOW" } }
      ]
    }
  ]
}
{% endschema %}
