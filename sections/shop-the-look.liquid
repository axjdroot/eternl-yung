{%- style -%}
  .sw-shop-look {
    padding-top: var(--pad-section-m);
    padding-bottom: var(--pad-section-m);
    background-color: var(--color-bg);
  }
  @media (min-width: 1024px) {
    .sw-shop-look {
      padding-top: var(--pad-section);
      padding-bottom: var(--pad-section);
    }
  }
  .sw-shop-look__heading {
    font-family: var(--font-heading-alt);
    font-size: 28px;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: var(--sp-6);
  }
  .sw-shop-look__grid {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }
  @media (min-width: 1024px) {
    .sw-shop-look__grid {
      flex-direction: row;
      align-items: flex-start;
      gap: var(--sp-12);
    }
  }
  
  .sw-shop-look__media-wrap {
    width: 100%;
  }
  @media (min-width: 1024px) {
    .sw-shop-look__media-wrap {
      width: 60%;
    }
  }
  .sw-shop-look__media {
    width: 100%;
    background-color: var(--color-bg-ghost);
    cursor: crosshair;
  }
  .sw-shop-look__media--4-5 { aspect-ratio: 4 / 5; }
  .sw-shop-look__media--1-1 { aspect-ratio: 1 / 1; }
  
  .sw-shop-look__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sw-shop-look__label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    text-transform: uppercase;
    margin-top: var(--sp-2);
    letter-spacing: 0.1em;
  }

  .sw-shop-look__products {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  @media (min-width: 1024px) {
    .sw-shop-look__products {
      width: 40%;
      position: sticky;
      top: 100px; /* Below header */
    }
  }

  .sw-mini-product {
    display: flex;
    background-color: var(--color-surface);
    padding: var(--sp-2);
    gap: var(--sp-4);
    align-items: center;
  }
  .sw-mini-product__thumb {
    width: 60px;
    height: 80px;
    background-color: var(--color-bg-chalk);
    flex-shrink: 0;
  }
  .sw-mini-product__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sw-mini-product__details {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .sw-mini-product__title {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-text);
    text-transform: uppercase;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sw-mini-product__price {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-muted);
    margin-bottom: var(--sp-2);
  }
  .sw-mini-product__swatches {
    display: flex;
    gap: 4px;
    margin-bottom: var(--sp-2);
  }
  .sw-mini-product__swatch {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--color-bg-ghost);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.2);
  }
  .sw-mini-btn {
    width: 100%;
    height: 32px;
    background-color: var(--color-bg-accent);
    color: var(--color-text-accent);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: filter var(--dur-fast) ease;
  }
  .sw-mini-btn:hover {
    filter: brightness(1.1);
  }
{%- endstyle -%}

<section class="sw-shop-look sw-reveal">
  <div class="sw-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="sw-shop-look__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="sw-shop-look__grid">
      <div class="sw-shop-look__media-wrap">
        <div class="sw-shop-look__media sw-shop-look__media--{{ section.settings.aspect_ratio }}">
          {%- if section.settings.image != blank -%}
            <img src="{{ section.settings.image | image_url: width: 1200 }}"
                 alt="{{ section.settings.label | escape | default: 'Shop the look' }}"
                 class="sw-shop-look__img"
                 loading="lazy">
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'sw-shop-look__img' }}
          {%- endif -%}
        </div>
        {%- if section.settings.label != blank -%}
          <div class="sw-shop-look__label">{{ section.settings.label }}</div>
        {%- endif -%}
      </div>

      <div class="sw-shop-look__products">
        {%- for block in section.blocks -%}
          {%- assign product = block.settings.product -%}
          {%- if product != blank -%}
            <div class="sw-mini-product" data-product-id="{{ product.id }}">
              <a href="{{ product.url }}" class="sw-mini-product__thumb">
                <img src="{{ product.featured_media | image_url: width: 120 }}"
                     alt="{{ product.title | escape }}"
                     class="sw-mini-product__img"
                     loading="lazy">
              </a>
              <div class="sw-mini-product__details">
                <a href="{{ product.url }}" class="sw-mini-product__title">{{ product.title }}</a>
                <div class="sw-mini-product__price">{{ product.price | money }}</div>
                
                {%- if product.has_only_default_variant == false -%}
                  <div class="sw-mini-product__swatches">
                    {%- for option in product.options_with_values -%}
                      {%- assign option_name = option.name | downcase -%}
                      {%- if option_name == 'color' or option_name == 'colour' -%}
                        {%- for value in option.values limit: 5 -%}
                          <span class="sw-mini-product__swatch" style="background-color: {{ value | downcase | replace: ' ', '' }};" title="{{ value }}"></span>
                        {%- endfor -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- if product.available -%}
                  <button type="button" 
                          class="sw-mini-btn sw-btn-quick-add"
                          data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                          aria-label="Add {{ product.title }} to cart">
                    <span>ADD TO BAG</span>
                  </button>
                {%- else -%}
                  <button type="button" class="sw-mini-btn" disabled style="background-color: var(--color-bg-ghost); color: var(--color-muted);">
                    SOLD OUT
                  </button>
                {%- endif -%}
              </div>
            </div>
          {%- else -%}
            <div class="sw-mini-product">
              <div class="sw-mini-product__thumb">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'sw-mini-product__img' }}
              </div>
              <div class="sw-mini-product__details">
                <span class="sw-mini-product__title">Example Piece {{ forloop.index }}</span>
                <div class="sw-mini-product__price">PKR 4,000</div>
                <button type="button" class="sw-mini-btn">ADD TO BAG</button>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop the Look",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP THE LOOK"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Image"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "4-5", "label": "Portrait (4:5)" },
        { "value": "1-1", "label": "Square (1:1)" }
      ],
      "default": "4-5"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Outfit Label",
      "default": "OUTFIT 01 — CITY ROAMER"
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the Look",
      "blocks": [
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
