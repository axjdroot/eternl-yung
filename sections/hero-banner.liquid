{%- style -%}
  .sw-hero-comic {
    position: relative;
    width: 100%;
    background-color: #388D73;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 400px;
  }

  /* Full Image Mode: Image defines height */
  {%- if section.settings.full_image -%}
    .sw-hero-comic {
      height: auto;
    }
    .sw-hero-comic__img-wrapper {
      position: relative;
      width: 100%;
    }
    .sw-hero-comic__img {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      width: 100%;
      height: auto;
      object-fit: initial;
    }
  {%- else -%}
    .sw-hero-comic {
      height: calc(100svh - 64px - 36px);
    }
    .sw-hero-comic__img-wrapper {
      position: absolute;
      inset: 0;
    }
    .sw-hero-comic__img {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  {%- endif -%}

  .sw-hero-comic__img--mobile {
    display: none;
  }

  @media (max-width: 749px) {
    .sw-hero-comic__img--desktop {
      display: none;
    }
    .sw-hero-comic__img--mobile {
      display: block;
    }
  }

  .sw-hero-comic__content-wrapper {
    position: absolute;
    bottom: var(--sp-8);
    left: var(--sp-6);
    z-index: 5;
    display: flex;
    align-items: flex-end;
    gap: var(--sp-4);
  }
  .sw-hero-comic__tag-wrapper {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }
  .sw-hero-comic__tag-title {
    font-family: var(--font-body);
    font-size: 24px;
    color: #000000;
    margin: 0;
    line-height: 1;
  }
  .sw-hero-comic__tag-sub {
    font-family: var(--font-body);
    font-size: 8px;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 var(--sp-2) 0;
    line-height: 1.2;
    opacity: 0.9;
  }
  .sw-hero-comic__cta {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .sw-hero-comic__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0,0,0,0.2);
  }
  .sw-hero-comic__cta svg {
    width: 18px;
    height: 18px;
  }
{%- endstyle -%}

<section class="sw-hero-comic sw-reveal">
  <div class="sw-hero-comic__img-wrapper">
    {%- comment -%} Desktop Image {%- endcomment -%}
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2400 }}"
           alt="Hero Banner Desktop"
           class="sw-hero-comic__img sw-hero-comic__img--desktop"
           loading="eager"
           decoding="async"
           width="{{ section.settings.image.width }}"
           height="{{ section.settings.image.height }}">
    {%- else -%}
      <img src="{{ 'banner-v1.1-d.webp' | asset_url }}"
           alt="Hero Banner Desktop"
           class="sw-hero-comic__img sw-hero-comic__img--desktop"
           loading="eager"
           decoding="async"
           width="1366"
           height="768">
    {%- endif -%}

    {%- comment -%} Mobile Image {%- endcomment -%}
    {%- if section.settings.image_mobile != blank -%}
      <img src="{{ section.settings.image_mobile | image_url: width: 1200 }}"
           alt="Hero Banner Mobile"
           class="sw-hero-comic__img sw-hero-comic__img--mobile"
           loading="eager"
           decoding="async"
           width="{{ section.settings.image_mobile.width }}"
           height="{{ section.settings.image_mobile.height }}">
    {%- else -%}
      <img src="{{ 'banner-v1.1-m.webp' | asset_url }}"
           alt="Hero Banner Mobile"
           class="sw-hero-comic__img sw-hero-comic__img--mobile"
           loading="eager"
           decoding="async"
           width="375"
           height="600">
    {%- endif -%}
  </div>

  <div class="sw-hero-comic__content-wrapper">
    <div class="sw-hero-comic__tag-wrapper">
      <p class="sw-hero-comic__tag-sub">
        {{ section.settings.tag_sub | default: 'ETERNL YUNG<br>A FRAGMENT OF YUNG VISION<br>2000//09-X, 24, EY' }}
      </p>
      <h2 class="sw-hero-comic__tag-title">
        {{ section.settings.tag_title | default: 'LOST IN THE MATRIX' }}
      </h2>
    </div>
    
    {%- if section.settings.cta_link != blank -%}
      <a href="{{ section.settings.cta_link }}" class="sw-hero-comic__cta sw-btn">
        {{ section.settings.cta_label | default: 'View More' }}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image"
    },
    {
      "type": "checkbox",
      "id": "full_image",
      "label": "Show Full Image (No Cropping)",
      "default": true
    },
    {
      "type": "textarea",
      "id": "tag_sub",
      "label": "Tag Sub-text",
      "default": "ETERNL YUNG\nA FRAGMENT OF YUNG VISION\n2000//09-X, 24, EY",
      "info": "Use <br> or new lines for line breaks"
    },
    {
      "type": "text",
      "id": "tag_title",
      "label": "Tag Title",
      "default": "LOST IN THE MATRIX"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Label",
      "default": "View More"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
