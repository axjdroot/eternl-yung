{%- style -%}
  .sw-related-section {
    padding: var(--pad-section-m) 0;
    background-color: #FFFFFF;
  }
  @media (min-width: 1024px) {
    .sw-related-section {
      padding: var(--pad-section) 0;
    }
  }
  .sw-related-header {
    margin-bottom: var(--sp-6);
  }
  .sw-related-title {
    font-family: var(--font-heading-alt);
    font-size: clamp(24px, 3vw, 32px);
    color: #111111;
  }

  /* Horizontal Scroll Grid */
  .sw-related-grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: var(--sp-4);
    padding-bottom: var(--sp-4); /* Space for hover shadows */
  }
  .sw-related-grid::-webkit-scrollbar {
    display: none;
  }
  
/* Product Card Override (for scroll snap) */
  .sw-related-grid .sw-product-card-wrap {
    flex: 0 0 85%;
    scroll-snap-align: start;
    text-decoration: none;
    transition: transform var(--dur-fast);
  }
  @media (min-width: 768px) {
    .sw-related-grid .sw-product-card-wrap { flex: 0 0 45%; }
  }
  @media (min-width: 1024px) {
    .sw-related-grid .sw-product-card-wrap { flex: 0 0 calc(33.333% - 11px); }
  }
{%- endstyle -%}

<section class="sw-related-section sw-reveal" data-section-id="{{ section.id }}">
  <div class="sw-container">
    <div class="sw-related-header">
      <h2 class="sw-related-title">{{ section.settings.heading | default: 'You may also like' }}</h2>
    </div>

    <div class="sw-related-grid">
      {%- assign rec_collection = product.collections.first -%}
      {%- if rec_collection != blank and rec_collection.products.size > 1 -%}
        {%- assign prod_count = 0 -%}
        {%- for prod in rec_collection.products limit: 4 -%}
          {%- if prod.id == product.id -%}{%- continue -%}{%- endif -%}
          {%- assign prod_count = prod_count | plus: 1 -%}
          {%- if prod_count > 3 -%}{%- break -%}{%- endif -%}
          {%- render 'product-card', product: prod -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <!-- Placeholder if no products found -->
          <div class="sw-product-card" style="flex: 0 0 85%; scroll-snap-align: start;">
            <div style="background:var(--color-bg-chalk); aspect-ratio:3/4; width:100%; display:flex; align-items:center; justify-content:center;">
              Preview
            </div>
            <div style="padding-top:12px; color:#FFF">Example Product {{ i }}</div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  // Ensure the global quick add logic in assets/theme.js triggers properly,
  // or duplicate the tiny slice here if snippet uses bespoke classes.
  // We removed the custom .js-quick-add code because snippet uses its own logic.
</script>

{% schema %}
{
  "name": "Related Products (Row)",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    }
  ],
  "presets": [
    {
      "name": "Related Products (Row)"
    }
  ]
}
{% endschema %}
