{%- style -%}
  .sw-newsletter-section {
    padding: var(--pad-section-m) 0;
    background-color: #FFFFFF;
    color: #111111;
  }
  @media (min-width: 1024px) {
    .sw-newsletter-section {
      padding: var(--pad-section) 0;
    }
  }

  .sw-newsletter-grid {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
  }
  @media (min-width: 768px) {
    .sw-newsletter-grid {
      flex-direction: row;
      justify-content: space-between;
      gap: var(--sp-12);
    }
    .sw-nl-about, .sw-nl-form-wrapper {
      width: 45%;
    }
  }

  .sw-nl-about {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: #444444;
  }

  .sw-nl-title {
    font-family: var(--font-heading-alt);
    font-size: clamp(24px, 3vw, 32px);
    color: #111111;
    margin-bottom: var(--sp-4);
  }

  .sw-nl-form {
    display: flex;
    position: relative;
    border-bottom: 1px solid #E0E0E0;
  }
  .sw-nl-input {
    width: 100%;
    height: 48px;
    background: transparent;
    border: none;
    color: #111111;
    font-family: var(--font-body);
    font-size: 14px;
    outline: none;
  }
  .sw-nl-input::placeholder {
    color: #777777;
  }
  .sw-nl-submit {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    background: #111111;
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #FFFFFF;
    transition: opacity var(--dur-fast);
  }
  .sw-nl-submit:hover {
    opacity: 0.8;
  }
  .sw-nl-submit svg {
    width: 16px;
    height: 16px;
  }
  .sw-nl-success {
    font-family: var(--font-body);
    font-size: 13px;
    color: #88B04B;
    margin-top: var(--sp-2);
  }
{%- endstyle -%}

<section class="sw-newsletter-section sw-reveal" data-section-id="{{ section.id }}">
  <div class="sw-container">
    <div class="sw-newsletter-grid">
      
      <!-- Left: About -->
      <div class="sw-nl-about">
        {{ section.settings.about_text | default: 'Established to break boundaries and redefine the streetwear scene. [shop] is an experiment of awkward thoughts.' | replace: '[shop]', shop.name }}
      </div>

      <!-- Right: Newsletter -->
      <div class="sw-nl-form-wrapper">
        <h3 class="sw-nl-title">{{ section.settings.heading | default: 'Stay in the loop with our weekly newsletter' }}</h3>
        
        {%- form 'customer', id: 'newsletter-form', class: 'sw-nl-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          
          <input
            id="NewsletterEmail"
            type="email"
            name="contact[email]"
            class="sw-nl-input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="Newsletter-error"
            {% elsif form.posted_successfully? %}
              aria-describedby="Newsletter-success"
            {% endif %}
            placeholder="Enter your email"
            required
          >
          <button type="submit" class="sw-nl-submit" name="commit" id="Subscribe" aria-label="Subscribe">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </button>
          
          {%- if form.posted_successfully? -%}
            <div class="sw-nl-success" id="Newsletter-success" tabindex="-1" autofocus>
              Thanks for subscribing!
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter & About",
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About Brand Text",
      "default": "Established to break boundaries and redefine the streetwear scene. AWKWRD is an experiment of awkward thoughts."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Newsletter Heading",
      "default": "Stay in the loop with our weekly newsletter"
    }
  ],
  "presets": [
    {
      "name": "Newsletter & About"
    }
  ]
}
{% endschema %}
