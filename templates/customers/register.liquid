{%- style -%}
  .sw-customer {
    padding-top: var(--sp-12);
    padding-bottom: var(--sp-16);
    background-color: var(--color-bg);
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sw-customer__inner {
    width: 100%;
    max-width: 400px;
  }
  .sw-customer__title {
    font-family: var(--font-heading-alt);
    font-size: 32px;
    color: var(--color-text);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: var(--sp-6);
  }
  .sw-customer-field {
    margin-bottom: var(--sp-4);
  }
  .sw-customer-field label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    text-transform: uppercase;
    margin-bottom: var(--sp-2);
  }
  .sw-customer-field input {
    width: 100%;
    height: 48px;
    background-color: var(--color-bg-ghost);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 14px;
    padding: 0 var(--sp-3);
  }
  .sw-customer__btn {
    width: 100%;
    height: 48px;
    background-color: var(--color-bg-accent);
    color: var(--color-text-accent);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    margin-top: var(--sp-2);
    margin-bottom: var(--sp-4);
  }
{%- endstyle -%}

<div class="sw-customer sw-reveal">
  <div class="sw-customer__inner">
    <h1 class="sw-customer__title">CREATE ACCOUNT</h1>
    
    {% form 'create_customer', novalidate: 'novalidate' %}
      {%- if form.errors -%}
        <div style="color: #ff3333; font-family:var(--font-body); font-size:13px; margin-bottom:16px;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="sw-customer-field">
        <label for="RegisterForm-FirstName">First Name</label>
        <input type="text" name="customer[first_name]" id="RegisterForm-FirstName" autocomplete="given-name">
      </div>

      <div class="sw-customer-field">
        <label for="RegisterForm-LastName">Last Name</label>
        <input type="text" name="customer[last_name]" id="RegisterForm-LastName" autocomplete="family-name">
      </div>

      <div class="sw-customer-field">
        <label for="RegisterForm-email">Email</label>
        <input type="email" name="customer[email]" id="RegisterForm-email" autocomplete="email" required>
      </div>

      <div class="sw-customer-field">
        <label for="RegisterForm-password">Password</label>
        <input type="password" name="customer[password]" id="RegisterForm-password" required>
      </div>

      <button type="submit" class="sw-customer__btn">CREATE</button>
      
      <div style="text-align: center; font-family: var(--font-body); font-size: 13px;">
        <a href="{{ routes.account_login_url }}" style="color: var(--color-muted); text-decoration: underline;">Already have an account? Log in</a>
      </div>
    {% endform %}
  </div>
</div>
