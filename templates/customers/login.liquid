{%- style -%}
  .sw-customer {
    padding-top: var(--sp-12);
    padding-bottom: var(--sp-16);
    background-color: var(--color-bg);
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sw-customer__inner {
    width: 100%;
    max-width: 400px;
  }
  .sw-customer__title {
    font-family: var(--font-heading-alt);
    font-size: 32px;
    color: var(--color-text);
    text-transform: uppercase;
    text-align: center;
    margin-bottom: var(--sp-6);
  }
  .sw-customer-field {
    margin-bottom: var(--sp-4);
  }
  .sw-customer-field label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    text-transform: uppercase;
    margin-bottom: var(--sp-2);
  }
  .sw-customer-field input {
    width: 100%;
    height: 48px;
    background-color: var(--color-bg-ghost);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 14px;
    padding: 0 var(--sp-3);
  }
  .sw-customer-field input:focus {
    outline: none;
    border-color: var(--color-text);
  }
  .sw-customer__btn {
    width: 100%;
    height: 48px;
    background-color: var(--color-bg-accent);
    color: var(--color-text-accent);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    margin-top: var(--sp-2);
    margin-bottom: var(--sp-4);
  }
  .sw-customer__links {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-body);
    font-size: 13px;
  }
  .sw-customer__links a {
    color: var(--color-muted);
    text-decoration: underline;
  }
{%- endstyle -%}

<div class="sw-customer sw-reveal">
  <div class="sw-customer__inner">
    <h1 class="sw-customer__title">LOGIN</h1>
    
    {% form 'customer_login', novalidate: 'novalidate' %}
      {%- if form.errors -%}
        <div style="color: #ff3333; font-family:var(--font-body); font-size:13px; margin-bottom:16px;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="sw-customer-field">
        <label for="CustomerEmail">Email</label>
        <input type="email" name="customer[email]" id="CustomerEmail" autocomplete="email" required>
      </div>

      {%- if form.password_needed -%}
        <div class="sw-customer-field">
          <label for="CustomerPassword">Password</label>
          <input type="password" name="customer[password]" id="CustomerPassword" autocomplete="current-password" required>
        </div>
      {%- endif -%}

      <button type="submit" class="sw-customer__btn">SIGN IN</button>

      <div class="sw-customer__links">
        <a href="#recover">Forgot password?</a>
        <a href="{{ routes.account_register_url }}">Create account</a>
      </div>
    {% endform %}
  </div>
</div>
